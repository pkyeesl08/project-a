# =============================================
# 동겜랭크 프로덕션 환경변수
# 이 파일을 .env.prod 로 복사 후 실제 값으로 채우세요.
# cp .env.prod.example .env.prod
# =============================================

# EC2 퍼블릭 IP 또는 도메인 (예: 43.201.12.34 또는 example.com)
SERVER_IP=여기에_EC2_IP_또는_도메인

# 데이터베이스 비밀번호 (자유롭게 설정)
DB_PASSWORD=여기에_강한_비밀번호

# JWT 서명 키 (터미널에서 openssl rand -hex 32 로 생성)
JWT_SECRET=여기에_32자_이상_랜덤_문자열

# Redis 비밀번호 (자유롭게 설정)
REDIS_PASSWORD=여기에_강한_비밀번호

# 외부 API (선택 — 없으면 관련 기능만 비활성화)
GOOGLE_MAPS_API_KEY=
RIOT_API_KEY=
NEXON_API_KEY=
PUBG_API_KEY=
STEAM_API_KEY=
