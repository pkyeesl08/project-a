# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=donggamerank

# Auth
JWT_SECRET=your-jwt-secret-change-in-production

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Server
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Google Maps
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Riot Games API
RIOT_API_KEY=your-riot-api-key

# Nexon Open API (https://openapi.nexon.com)
NEXON_API_KEY=your-nexon-api-key

# PUBG Developer API (https://developer.pubg.com)
# 무료 API 키 발급: developer.pubg.com → My Apps → Create App
# 국내 PC 배그: shard=kakao  /  스팀 글로벌: shard=steam
PUBG_API_KEY=your-pubg-api-key

# Steam Web API (https://steamcommunity.com/dev/apikey)
# 무료 키 발급: steamcommunity.com/dev/apikey (스팀 계정 필요)
STEAM_API_KEY=your-steam-api-key
